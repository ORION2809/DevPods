<?xml version="1.0" encoding="utf-8"?>
<!-- Conservative full-backup rules for pre-Android 12 devices (API < 31).
     Disables backup of all app data to prevent leakage of pairing tokens,
     session state, or audio metadata on older OS versions. -->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
    <exclude domain="root" path="." />
</full-backup-content>
